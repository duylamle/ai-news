# Reduce merge conflicts when both accounts append to data files
# JSONL files (1 entry/line) safe for union merge — git just adds new lines
data/entries-*.jsonl merge=union
# state.json + starred.json structured per-key, also safe for union
state.json merge=union
starred.json merge=union
# manifest.json is REGENERATED from data files — last writer wins is OK
# (don't use merge=union, would corrupt JSON structure)

# Force LF endings for cross-platform consistency
*.py text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
